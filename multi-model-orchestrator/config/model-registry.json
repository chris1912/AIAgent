  },
  "strategies": {
    "single": { "max_concurrent_writers": 1, "requires_worktrees": false },
    "parallel": { "max_concurrent_writers": 8, "requires_worktrees": true },
    "debate": { "max_concurrent_writers": 0, "requires_worktrees": false, "read_only_parallel": true },
    "dual-implementation": { "max_concurrent_writers": 2, "requires_worktrees": true },
    "pipeline": { "max_concurrent_writers": 1, "requires_worktrees": false, "ordered_stages": true }
  }
